; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GameJam"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Constants="*res://scripts/systems/Constants.gd"
Global="*uid://csct3f87r5402"
GameManager="*res://scripts/systems/GameManager.gd"
AudioManager="*res://scripts/systems/AudioManager.gd"
AlcoholSystem="*res://scripts/systems/AlcoholSystem.gd"
TimeManager="*res://scripts/systems/TimeManager.gd"
DialogueSystem="*res://scripts/systems/DialogueSystem.gd"

[dotnet]

project/assembly_name="GameJam"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
