[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/systems/GameManager.gd" id="1_gm"]
[ext_resource type="Script" path="res://scripts/systems/AudioManager.gd" id="2_am"]
[ext_resource type="Script" path="res://scripts/systems/AlcoholSystem.gd" id="3_as"]
[ext_resource type="Script" path="res://scripts/systems/TimeManager.gd" id="4_tm"]
[ext_resource type="Script" path="res://scripts/systems/DialogueSystem.gd" id="5_ds"]
[ext_resource type="Script" path="res://scripts/ui/HUD.gd" id="6_hud"]

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="GameManager" type="Node" parent="."]
script = ExtResource("1_gm")
editor_description = "Manages global game state and scene transitions"

[node name="AudioManager" type="Node" parent="."]
script = ExtResource("2_am")
editor_description = "Handles music and sfx channels"

[node name="AlcoholSystem" type="Node" parent="."]
script = ExtResource("3_as")
editor_description = "Tracks alcohol levels and related effects"

[node name="TimeManager" type="Node" parent="."]
script = ExtResource("4_tm")
editor_description = "Tracks elapsed time towards the deadline"

[node name="DialogueSystem" type="Node" parent="."]
script = ExtResource("5_ds")
editor_description = "Manages dialogue tree state"

[node name="CurrentScene" type="Node" parent="."]
editor_description = "Placeholder node where active room scenes will be loaded"

[node name="HUD" type="CanvasLayer" parent="."]
script = ExtResource("6_hud")
editor_description = "UI overlay rendered on top of everything else"
