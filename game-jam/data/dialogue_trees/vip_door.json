        "text": "The bouncer blocks the velvet rope. 'VIPs only beyond this point. Pass?'",
        "options": [
          {
            "text": "Show VIP Pass & Enter",
            "next": "enter",
            "disabled_if": { "flag": "djDefeated", "is": false }
          },
          {
            "text": "Walk away.",
            "next": "exit"
          }
        ]
      },
      "enter": {
        "text": "He nods and unhooks the rope. 'Enjoy your night.'",
        "options": [
          { "text": "[Enter VIP Room]", "next": "exit", "triggerGlobal": "transitionToVIP" }
        ]
      },
      "exit": { "text": null, "options": [] }
    }
  }
}
