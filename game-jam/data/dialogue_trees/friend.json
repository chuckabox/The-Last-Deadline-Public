              {
                "text": "[Keep drinking (MEDIUM)] I love alcohol.",
                "next": "phoneTrigger",
                "triggerGlobal": "increaseAlcohol"
              },
              {
                "text": "[Chug (HARD)] Nah bro, I'm him.",
