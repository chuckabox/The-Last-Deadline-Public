{
  "id": "FratBro",
  "name": "Frat Bro",
  "dialogue": {
    "start": "talk",
    "nodes": {
      "talk": {
        "variants": [
          {
            "conditions": [
              { "flag": "fratBroDefeated", "is": true },
              { "flag": "fatChudDefeated", "is": false }
            ],
            "text": "Sick shots earlier, bro! Now stop stalling and go find Fat Chud over by the taps.",
            "options": [
              { "text": "[Exit] Right.", "next": "exit" }
            ]
          },
          {
            "conditions": [
              { "flag": "fratBroDefeated", "is": true },
              { "flag": "fatChudDefeated", "is": true }
            ],
            "text": "I already told you everything I know, man! Go see the DJ and get out of here before the deadline hits!",
            "options": [
              { "text": "[Exit] Okay.", "next": "exit" }
            ]
          },
          {
            "condition": { "flag": "bartenderDefeated", "is": false },
            "text": "Whoa, who are you? I only talk to regulars or anyone the Bartender vouches for. Step back, bro.",
            "options": [
              { "text": "[Exit] Fine.", "next": "exit" }
            ]
          },
          {
            "condition": { "flag": "bartenderDefeated", "is": true },
            "text": "In a rush, huh? Beat me at pong and I'll tell you what the DJ dropped. Otherwise... bottoms up, loser!",
            "options": [
              { "text": "[Help Them] You're on!", "next": "pongPrompt" },
              { "text": "[Help Them] Easy money.", "next": "pongPrompt" },
              { "text": "[Exit] Maybe later.", "next": "exit" }
            ]
          }
        ]
      },
      "pongPrompt": {
        "text": "House rules. Three cups, three shots. Sink 'em or sink suds, your call. Step up to the table when you're ready to get schooled.",
        "options": [
          { "text": "[Play Game] Step up to the table.", "next": "pongGame" },
          { "text": "[Exit] Back out.", "next": "exit" }
        ]
      },
      "pongGame": {
        "text": "[Triggers Beer Pong Minigame]",
        "minigame": "beer_pong",
        "options": [
          { "text": "[Win]", "next": "victoryCheck", "setFlag": { "fratBroDefeated": true } },
          { "text": "[Lose]", "next": "failedGame", "setFlag": { "fratGuyFailed": true } }
        ]
      },
      "victoryCheck": {
        "variants": [
          {
            "condition": { "flag": "fatChudDefeated", "is": false },
            "text": "Sick shots! Alright, I respect it. Go find that big guy over by the taps—Fat Chud. He's the only one who knows the code for the floor gate.",
            "options": [
              { "text": "[Exit] Thanks.", "next": "exit" }
            ]
          },
          {
            "condition": { "flag": "fatChudDefeated", "is": true },
            "text": "Unbelievable! You're a legend, bro. The DJ has the VIP keycard. Go show him some moves before your deadline hits!",
            "options": [
              { "text": "[Exit] On it.", "next": "exit" }
            ]
          }
        ]
      },
      "failedGame": {
        "text": "Airball! That's pathetic, man. House rules: you miss, you chug. Down it!",
        "options": [
          { "text": "[Drink] Ugh, fine.", "next": "exit", "triggerGlobal": "increaseAlcohol" }
        ]
      },
      "exit": {
        "text": null,
        "options": []
      }
    }
  }
}