{
  "id": "FratBro",
  "name": "Frat Bro",
  "dialogue": {
    "start": "talk",
    "nodes": {
      "talk": {
        "variants": [
          {
            "condition": {
              "flag": "fratBroDefeated",
              "is": true
            },
            "text": "I already told you everything I know. Go see the DJ and get out of here!",
            "options": [
              {
                "text": "Right.",
                "next": "exit"
              }
            ]
          },
          {
            "condition": {
              "flag": "bartenderDefeated",
              "is": false
            },
            "text": "Who are you? I only talk to regulars or anyone the Bartender vouches for.",
            "options": [
              {
                "text": "Fine.",
                "next": "exit"
              }
            ]
          },
          {
            "condition": {
              "flag": "bartenderDefeated",
              "is": true
            },
            "text": "In a rush? Beat me at pong and I'll tell you what the DJ dropped. Otherwise... bottoms up, loser!",
            "options": [
              {
                "text": "[Accept] You're on!",
                "next": "pongPrompt"
              },
              {
                "text": "[Trash talk] Easy money.",
                "next": "pongPrompt"
              },
              {
                "text": "Maybe later.",
                "next": "exit"
              }
            ]
          }
        ]
      },
      "pongPrompt": {
        "text": "House rules. Three cups, three shots. Sink 'em or sink suds, your call. Step up to the table when you're ready.",
        "options": [
          {
            "text": "[Step up to the table]",
            "next": "pongGame"
          },
          {
            "text": "Back out.",
            "next": "exit"
          }
        ]
      },
      "pongGame": {
        "text": "[Triggers Beer Pong Minigame]",
        "minigame": "beer_pong",
        "options": [
          {
            "text": "[Win]",
            "next": "victoryCheck",
            "setFlag": {
              "fratBroDefeated": true
            }
          },
          {
            "text": "[Lose]",
            "next": "failedGame",
            "setFlag": {
              "fratGuyFailed": true
            }
          }
        ]
      },
      "victoryCheck": {
        "variants": [
          {
            "condition": {
              "flag": "fatChudDefeated",
              "is": false
            },
            "text": "Sick shots! Go find that big guy over by the taps—Fat Chud. He's the only one who knows the code for the floor gate.",
            "options": [
              {
                "text": "Thanks.",
                "next": "exit"
              }
            ]
          },
          {
            "condition": {
              "flag": "fatChudDefeated",
              "is": true
            },
            "text": "Unbelievable! You're a legend. The DJ has the VIP keycard. Go show him some moves before the deadline hits!",
            "options": [
              {
                "text": "On it.",
                "next": "exit"
              }
            ]
          }
        ]
      },
      "failedGame": {
        "text": "Airball! That's pathetic, man. House rules: you miss, you chug. Down it!",
        "options": [
          {
            "text": "[Drink]",
            "next": "exit",
            "triggerGlobal": "increaseAlcohol"
          }
        ]
      },
      "exit": {
        "text": null,
        "options": []
      }
    }
  }
}
