{
  "id": "Bartender",
  "name": "Bartender",
  "dialogue": {
    "start": "talk",
    "nodes": {
      "talk": {
        "variants": [
          {
            "condition": {
              "flag": "bartenderDefeated",
              "is": true
            },
            "text": "You've got your info. Now move along to Frat Bro or Fat Chud, I'm a busy bee.",
            "options": [
              {
                "text": "[Exit] Cheers.",
                "next": "exit"
              }
            ]
          },
          {
            "condition": {
              "flag": "hasSpokenToFriend",
              "is": true
            },
            "text": "Look, kid, I'm slammed. You want my help? Help me with these orders first.",
            "options": [
              {
                "text": "[Help Them] Lay it on me.",
                "next": "ordersPrompt"
              },
              {
                "text": "[Help Them] Sure.",
                "next": "ordersPrompt"
              },
              {
                "text": "[Exit] I'll be back later.",
                "next": "exit"
              }
            ]
          }
        ]
      },
      "ordersPrompt": {
        "text": "Three drinks, three customers, no mistakes. Memorise the order or I'm pouring this swill down your throat instead.",
        "options": [
          {
            "text": "[Play Game] I got this.",
            "next": "bartenderGame"
          },
          {
            "text": "[Exit] Forget it.",
            "next": "exit"
          }
        ]
      },
      "bartenderGame": {
        "text": "[Triggers Bartender Memory Game]",
        "minigame": "bartender_memory",
        "options": [
          {
            "text": "[Win]",
            "next": "passedGame",
            "setFlag": {
              "bartenderDefeated": true
            }
          },
          {
            "text": "[Lose]",
            "next": "failedGame",
            "setFlag": {
              "bartenderFailed": true
            }
          }
        ]
      },
      "passedGame": {
        "text": "Decent work. You've got a steady hand. Go find the Frat Bro at a table or Fat Chud being lazy. They know the floor.",
        "options": [
          {
            "text": "[Exit] Thanks.",
            "next": "exit"
          }
        ]
      },
      "failedGame": {
        "text": "You're useless. You need to relax and get out of the way.",
        "options": [
          {
            "text": "[Drink] Aw man...",
            "next": "exit",
            "triggerGlobal": "increaseAlcohol"
          }
        ]
      },
      "exit": {
        "text": null,
        "options": []
      }
    }
  }
}
